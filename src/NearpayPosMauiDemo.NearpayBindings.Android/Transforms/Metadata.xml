<metadata>
  <!-- Prevent generating a C# override for java.lang.Object.finalize() -->
  <remove-node path="/api/package[@name='io.nearpay.sdk']/class[@name='NearPay']/method[@name='finalize']" />

  <!-- The SDK contains many Parcelable *Creator types that cause signature mismatches in generated C#.
       We don't need them for our usage, so we remove them from the bound API surface. -->
  <remove-node path="/api/package/class[contains(@name,'.Creator')]" />

  <!-- Remove UI/ViewBinding and receipt UI packages from the binding to avoid adapter/view-binding signature issues.
       The demo app relies on the high-level SDK entry points + listeners only. -->
  <remove-node path="/api/package[@name='io.nearpay.sdk.databinding']" />
  <remove-node path="/api/package[@name='io.nearpay.sdk.receipt.reconcile']" />
  <remove-node path="/api/package[@name='io.nearpay.sdk.receipt.transaction']" />
  <remove-node path="/api/package[@name='io.nearpay.sdk_internal.utils']" />

  <!-- Avoid C# EventArgs name collisions (the generator defaults to generic names like FailureEventArgs/SuccessEventArgs). -->
  <attr path="/api/package[@name='io.nearpay.sdk.utils.listeners']/interface[@name='BitmapListener']/method[@name='result' and count(parameter)=1]" name="argsType">BitmapListenerResultEventArgs</attr>

  <attr path="/api/package[@name='io.nearpay.sdk.utils.listeners']/interface[@name='CancelListener']/method[@name='onCancel' and count(parameter)=1]" name="argsType">CancelListenerCancelledEventArgs</attr>
