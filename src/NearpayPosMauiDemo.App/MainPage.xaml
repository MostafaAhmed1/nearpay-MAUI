<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:NearpayPosMauiDemo.App.Converters"
             x:Class="NearpayPosMauiDemo.App.MainPage"
             FlowDirection="RightToLeft"
             Title="NearPay POS Demo">

    <!--
      IMPORTANT:
      بعض بيئات التشغيل (خصوصاً مع Fast Deployment) قد تفشل في تحميل Application Resources بشكل صحيح.
      لتجنب Crash قبل حتى ظهور الشاشة، نعرّف أهم الـ Resources محلياً داخل الصفحة كـ fallback.
    -->
    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />

            <!-- Minimal palette -->
            <Color x:Key="Primary">#1B3A57</Color>
            <Color x:Key="PrimaryDarkText">#0B1220</Color>
            <Color x:Key="Secondary">#E6EEF5</Color>
            <Color x:Key="Success">#16A34A</Color>
            <Color x:Key="Warning">#F59E0B</Color>
            <Color x:Key="Danger">#DC2626</Color>
            <Color x:Key="White">#FFFFFF</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="CardStroke">#D6DEE8</Color>
            <Color x:Key="Gray200">#C8C8C8</Color>
            <Color x:Key="Gray300">#ACACAC</Color>
            <Color x:Key="Gray500">#6E6E6E</Color>
            <Color x:Key="Gray600">#404040</Color>
            <Color x:Key="Gray900">#212121</Color>
            <Color x:Key="Gray950">#141414</Color>

            <!-- Typography -->
            <Style x:Key="SectionTitleStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark={StaticResource White}}" />
            </Style>

            <Style x:Key="CaptionStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            </Style>

            <!-- Field styles -->
            <Style x:Key="FieldLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            </Style>

            <Style x:Key="FieldBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource CardStroke}, Dark={StaticResource Gray600}}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource Gray900}}" />
            </Style>

            <Style x:Key="FieldEntryStyle" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark={StaticResource White}}" />
                <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
            </Style>

            <Style x:Key="FieldPickerStyle" TargetType="Picker">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark={StaticResource White}}" />
            </Style>

            <Style x:Key="AmountEntryStyle" TargetType="Entry">
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark={StaticResource White}}" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <!-- Card container -->
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource Gray950}}" />
                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource CardStroke}, Dark={StaticResource Gray600}}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 16" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Shadow">
                    <Shadow Brush="#000000" Opacity="0.10" Offset="0,6" Radius="14" />
                </Setter>
            </Style>

            <!-- Buttons -->
            <Style x:Key="ButtonBase" TargetType="Button">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="14,14" />
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
            </Style>
            <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
            </Style>
            <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryDarkText}" />
            </Style>
            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Loading indicator -->
            <Border IsVisible="{Binding IsBusy}"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#CCFFFFFF, Dark=#CC000000}"
                    StrokeShape="RoundRectangle 14"
                    Padding="12">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" />
                    <Label Text="{Binding BusyMessage}" VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Header -->
            <Border Style="{DynamicResource CardBorderStyle}"
                    BackgroundColor="{DynamicResource Primary}"
                    StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                    <Border WidthRequest="44" HeightRequest="44"
                            StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 12"
                            VerticalOptions="Center"
                            HorizontalOptions="Center">
                        <Label Text="NP"
                               FontFamily="OpenSansSemibold"
                               TextColor="{DynamicResource Primary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="NearPay POS Demo"
                               FontFamily="OpenSansSemibold"
                               FontSize="18"
                               TextColor="White" />
                        <Label Text="واجهة اختبار احترافية (شاشة واحدة)"
                               Style="{DynamicResource CaptionStyle}"
                               TextColor="#E9F0F7" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- One Button Flow -->
            <Border Style="{DynamicResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="إعدادات التشغيل (شاشة واحدة + زر واحد)" Style="{DynamicResource SectionTitleStyle}" />
                    <Label Text="التسلسل: Initialize → Setup → Purchase"
                           Style="{DynamicResource CaptionStyle}" />

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                            <Label Text="البيئة" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Picker Style="{DynamicResource FieldPickerStyle}"
                                        ItemsSource="{Binding EnvironmentOptions}"
                                        SelectedItem="{Binding SelectedEnvironment}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                            <Label Text="طريقة الدخول" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Picker Style="{DynamicResource FieldPickerStyle}"
                                        ItemsSource="{Binding AuthModeOptions}"
                                        SelectedItem="{Binding SelectedAuthMode}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="6">
                            <Label Text="Auth Value (JWT / Email / Mobile)" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Entry Style="{DynamicResource FieldEntryStyle}"
                                       Placeholder="اتركه فارغاً عند UserEnter"
                                       Text="{Binding AuthValue}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                            <Label Text="المبلغ (minor units)" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Entry Style="{DynamicResource AmountEntryStyle}"
                                       Keyboard="Numeric"
                                       Text="{Binding AmountMinor}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                            <Label Text="مهلة الإنهاء (ث)" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Entry Style="{DynamicResource FieldEntryStyle}"
                                       Keyboard="Numeric"
                                       Text="{Binding FinishTimeoutSeconds}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Customer Reference (اختياري)" Style="{DynamicResource FieldLabelStyle}" />
                        <Border Style="{DynamicResource FieldBorderStyle}">
                            <Entry Style="{DynamicResource FieldEntryStyle}"
                                   Placeholder="أي رقم/نص"
                                   Text="{Binding CustomerReferenceNumber}" />
                        </Border>
                    </VerticalStackLayout>

                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="6" ColumnSpacing="8">
                        <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding EnableReceiptUi}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="Receipt UI" VerticalTextAlignment="Center" />
                        <CheckBox Grid.Row="1" Grid.Column="0" IsChecked="{Binding EnableUiDismiss}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="UI Dismiss" VerticalTextAlignment="Center" />
                    </Grid>

                    <Button Text="تشغيل (Initialize → Setup → Purchase)"
                            Style="{DynamicResource SuccessButton}"
                            Command="{Binding RunOneButtonPurchaseCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Tools + logs -->
            <Border Style="{DynamicResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Button Text="تجهيز الجهاز (صلاحيات)"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding PrepareDeviceCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="فحص التوافق"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding DeviceCompatibilityCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Text="فحص الجلسة"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding GetUserSessionCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>

                    <Button Text="إعدادات NearPay"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding OpenSettingsCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="تحميل Plugin (Sandbox)"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding DownloadPaymentPluginSandboxCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Text="تحميل Plugin (Production)"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding DownloadPaymentPluginProductionCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>

                    <Button Text="مساعدة"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding ShowHelpCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <Label Text="الحالة" Style="{DynamicResource SectionTitleStyle}" />
                    <Label Text="{Binding StatusMessage}" />

                    <Label Text="السجل (Log)" Style="{DynamicResource SectionTitleStyle}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="نسخ السجل"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding CopyLogCommand}" />
                        <Button Grid.Column="1"
                                Text="مسح السجل"
                                Style="{DynamicResource DangerButton}"
                                Command="{Binding ClearLogCommand}" />
                    </Grid>

                    <Border StrokeThickness="1"
                            Stroke="{DynamicResource CardStroke}"
                            StrokeShape="RoundRectangle 12"
                            Padding="10">
                        <Editor Text="{Binding LogText}"
                                IsReadOnly="True"
                                AutoSize="TextChanges"
                                HeightRequest="260"
                                FlowDirection="LeftToRight" />
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
