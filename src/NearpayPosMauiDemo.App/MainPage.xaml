<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NearpayPosMauiDemo.App.MainPage"
             FlowDirection="RightToLeft"
             Title="NearPay POS Demo">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Header -->
            <Border Style="{StaticResource CardBorderStyle}"
                    BackgroundColor="{StaticResource Primary}"
                    StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                    <Border WidthRequest="44" HeightRequest="44"
                            StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 12"
                            VerticalOptions="Center"
                            HorizontalOptions="Center">
                        <Label Text="NP"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="NearPay POS Demo"
                               FontFamily="OpenSansSemibold"
                               FontSize="18"
                               TextColor="White" />
                        <Label Text="واجهة اختبار احترافية (شاشة واحدة)"
                               Style="{StaticResource CaptionStyle}"
                               TextColor="#E9F0F7" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Amount (primary) -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="المبلغ" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="أدخل القيمة بالـ minor units: مثال 1455 = 14.55"
                           Style="{StaticResource CaptionStyle}" />

                    <Border Style="{StaticResource FieldBorderStyle}">
                        <Entry Style="{StaticResource AmountEntryStyle}"
                               Keyboard="Numeric"
                               Text="{Binding AmountMinor}"
                               FlowDirection="LeftToRight" />
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Customer Ref (اختياري)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Placeholder="أي رقم/نص"
                                       Text="{Binding CustomerReferenceNumber}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Finish Timeout (sec)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Keyboard="Numeric"
                                       Text="{Binding FinishTimeoutSeconds}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0"
                                Text="شراء (Purchase)"
                                Style="{StaticResource SuccessButton}"
                                Command="{Binding PurchaseCommand}" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Text="استرجاع (Refund)"
                                Style="{StaticResource WarningButton}"
                                Command="{Binding RefundCommand}" />
                        <Button Grid.Row="1" Grid.Column="0"
                                Text="عكس (Reverse)"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ReverseCommand}" />
                        <Button Grid.Row="1" Grid.Column="1"
                                Text="تسوية (Reconcile)"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ReconcileCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Advanced fields -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="إعدادات الدخول (Authentication)" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="استخدم UserEnter للتجربة السريعة، أو JWT/Email/Mobile حسب إعداد حساب NearPay."
                           Style="{StaticResource CaptionStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Environment" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Picker Style="{StaticResource FieldPickerStyle}"
                                        ItemsSource="{Binding EnvironmentOptions}"
                                        SelectedItem="{Binding SelectedEnvironment}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Auth Mode" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Picker Style="{StaticResource FieldPickerStyle}"
                                        ItemsSource="{Binding AuthModeOptions}"
                                        SelectedItem="{Binding SelectedAuthMode}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.ColumnSpan="2" Spacing="6">
                            <Label Text="Auth Value (JWT / Email / Mobile)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Placeholder="JWT / Email / Mobile"
                                       Text="{Binding AuthValue}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Locale" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Placeholder="ar-SA"
                                       Text="{Binding Locale}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="TID (اختياري)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Placeholder="PS239210"
                                       Text="{Binding Tid}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="حقول Refund / Reverse" Style="{StaticResource SectionTitleStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                        <VerticalStackLayout Grid.ColumnSpan="2" Spacing="6">
                            <Label Text="Transaction UUID" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Placeholder="مطلوب لـ Refund/Reverse"
                                       Text="{Binding TransactionUuid}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Admin PIN (اختياري)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource FieldBorderStyle}">
                                <Entry Style="{StaticResource FieldEntryStyle}"
                                       Placeholder="0000"
                                       IsPassword="True"
                                       Text="{Binding AdminPin}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="خيارات الواجهة" Style="{StaticResource FieldLabelStyle}" />
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="6" ColumnSpacing="8">
                                <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding EnableReceiptUi}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="Receipt UI" VerticalTextAlignment="Center" />
                                <CheckBox Grid.Row="1" Grid.Column="0" IsChecked="{Binding EnableUiDismiss}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="UI Dismiss" VerticalTextAlignment="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Setup buttons + logs -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="تهيئة" Style="{StaticResource PrimaryButton}" Command="{Binding InitializeCommand}" />
                        <Button Grid.Column="1" Text="Setup" Style="{StaticResource PrimaryButton}" Command="{Binding SetupCommand}" />
                        <Button Grid.Column="2" Text="مسح السجل" Style="{StaticResource PrimaryButton}" Command="{Binding ClearLogCommand}" />
                    </Grid>

                    <Label Text="الحالة" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="{Binding StatusMessage}" />

                    <Label Text="السجل (Log)" Style="{StaticResource SectionTitleStyle}" />
                    <CollectionView ItemsSource="{Binding Logs}" HeightRequest="260">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0" Padding="8,6"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray900}}"
                                        StrokeShape="RoundRectangle 10">
                                    <Label Text="{Binding .}" FontSize="12" LineBreakMode="WordWrap" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
