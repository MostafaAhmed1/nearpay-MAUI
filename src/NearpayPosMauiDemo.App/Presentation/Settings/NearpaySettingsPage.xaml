<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NearpayPosMauiDemo.App.Presentation.Settings.NearpaySettingsPage"
             Title="إعدادات NearPay"
             FlowDirection="RightToLeft">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF7F9FC, Dark=#FF141414}"
                    StrokeShape="RoundRectangle 16"
                    Padding="14">
                <VerticalStackLayout Spacing="6">
                    <Label Text="هذه الشاشة لحفظ إعدادات NearPay محلياً على الجهاز (بدون إعادة إدخالها كل مرة)."
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#404040, Dark=#ACACAC}" />
                    <Label Text="تنبيه: لا تضع الـ PEM داخل التطبيق ولا ترفع أسرارك على GitHub."
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FCA5A5}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{DynamicResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="بيانات الاتصال (Dashboard)" Style="{DynamicResource SectionTitleStyle}" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                            <Label Text="Environment" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Picker Style="{DynamicResource FieldPickerStyle}"
                                        ItemsSource="{Binding EnvironmentOptions}"
                                        SelectedItem="{Binding SelectedEnvironment}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                            <Label Text="Auth Mode" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Picker Style="{DynamicResource FieldPickerStyle}"
                                        ItemsSource="{Binding AuthModeOptions}"
                                        SelectedItem="{Binding SelectedAuthMode}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="6">
                            <Label Text="Auth Value (JWT / Email / Mobile)" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Editor AutoSize="TextChanges"
                                        MinimumHeightRequest="110"
                                        Text="{Binding AuthValue}"
                                        Placeholder="ألصق JWT هنا أو أدخل Email/Mobile"
                                        FlowDirection="LeftToRight"
                                        TextColor="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark={StaticResource White}}" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{DynamicResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="بيانات الـ Terminal" Style="{DynamicResource SectionTitleStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="TID" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Entry Style="{DynamicResource FieldEntryStyle}"
                                       Placeholder="مثال: PS239210"
                                       Text="{Binding Tid}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Locale" Style="{DynamicResource FieldLabelStyle}" />
                            <Border Style="{DynamicResource FieldBorderStyle}">
                                <Entry Style="{DynamicResource FieldEntryStyle}"
                                       Placeholder="ar-SA"
                                       Text="{Binding Locale}"
                                       FlowDirection="LeftToRight" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="API Key (اختياري)" Style="{DynamicResource FieldLabelStyle}" />
                        <Border Style="{DynamicResource FieldBorderStyle}">
                            <Entry Style="{DynamicResource FieldEntryStyle}"
                                   Placeholder="إن كانت لديك API Key"
                                   Text="{Binding ApiKey}"
                                   FlowDirection="LeftToRight" />
                        </Border>
                        <Label Text="ملاحظة: بعض نسخ SDK لا تستخدم API Key داخل التطبيق، لكن نحفظها هنا للمرجع."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#404040, Dark=#ACACAC}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="حفظ الإعدادات"
                        Style="{DynamicResource SuccessButton}"
                        Command="{Binding SaveCommand}" />
                <Button Grid.Column="1"
                        Text="مسح الإعدادات"
                        Style="{DynamicResource DangerButton}"
                        Command="{Binding ClearCommand}" />
            </Grid>

            <Button Text="العودة للرئيسية"
                    Style="{DynamicResource PrimaryButton}"
                    Command="{Binding BackCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
